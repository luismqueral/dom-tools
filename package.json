{
  "name": "dom-tools",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:js": "rollup -c build/rollup.config.mjs",
    "build:css": "tailwindcss -c tailwind.config.js -i src/tailwind.input.css -o dist/dom-tools.css --minify",
    "build": "npm run build:css && npm run build:js",
    "dev:js": "rollup -c build/rollup.config.mjs --watch",
    "dev:css": "tailwindcss -c tailwind.config.js -i src/tailwind.input.css -o dist/dom-tools.css --watch",
    "dev": "npm run dev:css & npm run dev:js",
    "bridge": "node bridge-server.js"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.3",
    "tailwindcss": "^3.4.19"
  }
}
